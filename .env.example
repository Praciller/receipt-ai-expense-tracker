# AI router
AI_PROVIDER_PRIORITY=ninearm,gemini,groq,cerebras
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=1
AI_RETRY_BACKOFF_SECONDS=2
ENABLE_AI_PARSE_CACHE=true
AI_PARSE_CACHE_TTL_SECONDS=86400
AI_PARSE_CACHE_DIR=.cache/ai
ENABLE_SAFE_FALLBACK=true
RETURN_PROVIDER_METADATA=true
MOCK_AI_MODE=false

# 9arm Gateway
NINEARM_API_KEY=
NINEARM_BASE_URL=https://gateway.9arm.co/v1
NINEARM_RECEIPT_MODEL=qwen3.6-35b-a3b
NINEARM_FALLBACK_MODEL=qwen3.6-35b-a3b
NINEARM_SUPPORTS_IMAGE_INPUT=false

# Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_RECEIPT_MODEL=gemini-2.5-flash
GEMINI_RECEIPT_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_SUPPORTS_IMAGE_INPUT=true

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_RECEIPT_FALLBACK_MODEL=qwen/qwen3-32b
GROQ_JSON_REPAIR_MODEL=llama-3.1-8b-instant
GROQ_SUPPORTS_IMAGE_INPUT=false

# Cerebras
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_RECEIPT_FALLBACK_MODEL=gpt-oss-120b
CEREBRAS_SUPPORTS_IMAGE_INPUT=false

# Browser storage
NEXT_PUBLIC_STORAGE_MODE=indexeddb

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
MAX_RECEIPT_IMAGE_MB=5
